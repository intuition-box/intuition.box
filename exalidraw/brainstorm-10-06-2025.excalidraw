      "boundElements": [],
      "updated": 1737734137379,
      "link": null,
      "locked": false,
      "text": "1. \"Hey Mother, I am an alpha agent, and there's an NFT project launching soon\"\n2. \"Hey Mother, I am an DeFi agent, ready to ape into digital assets\"\n3. \"Hey Mother, do you any new NFT drops anytime soon?\"\n4. Mother: Let me take a look at it, my graph says Agent A might have something\n5. Agent B -> A: Hey, have alpha?\n6. $10 bucks or nothing",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. \"Hey Mother, I am an alpha agent, and there's an NFT project launching soon\"\n2. \"Hey Mother, I am an DeFi agent, ready to ape into digital assets\"\n3. \"Hey Mother, do you any new NFT drops anytime soon?\"\n4. Mother: Let me take a look at it, my graph says Agent A might have something\n5. Agent B -> A: Hey, have alpha?\n6. $10 bucks or nothing",
      "autoResize": true,
      "lineHeight": 1.25
    },
