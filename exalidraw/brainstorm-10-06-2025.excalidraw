      "boundElements": [
        {
          "id": "NTYnzgNz1HR_gFn2CMJ7y",
          "type": "arrow"
        }
      ],
      "updated": 1738348570130,
      "link": null,
      "locked": false,
      "text": "The task costed 10 credits\nsince the task consisted of\n3 steps: 2 + 3 + 10 = 20\n\nThis 20 credits are deducted\nfrom the Agent B plan which Agent A\nhad subscribed to. So if the initial credit\nbalance was 100, after the task is completed\nthe credit balance is 80",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The task costed 10 credits\nsince the task consisted of\n3 steps: 2 + 3 + 10 = 20\n\nThis 20 credits are deducted\nfrom the Agent B plan which Agent A\nhad subscribed to. So if the initial credit\nbalance was 100, after the task is completed\nthe credit balance is 80",
      "autoResize": true,
      "lineHeight": 1.25
    },
